# --- データベース接続 ---
# ローカル開発: libSQL のローカルファイルを使う
TURSO_DATABASE_URL=file:./local.db

# 本番 (Vercel): Turso のリモートURLとトークンを設定する
# TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
# TURSO_AUTH_TOKEN=<your-turso-auth-token>

# --- 認証 (Better Auth) --- EP33
# ログイン状態が本物かを確かめる合言葉。下記コマンドで生成して貼る:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=<32バイト以上のランダム文字列>
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Googleログイン (GCP) --- EP33
# GCP → OAuth 2.0 クライアントID（ウェブアプリケーション）で発行する。
# 承認済みのリダイレクトURI に下記を「完全一致」で登録すること:
#   http://localhost:3000/api/auth/callback/google
# ※ 未設定の間は Google ボタンが自動で非表示になり、メール+パスワードで動作確認できる。
# GOOGLE_CLIENT_ID=<クライアントID>
# GOOGLE_CLIENT_SECRET=<クライアントシークレット・絶対に共有しない>

# --- サムネイル画像の置き場 (Vercel Blob) --- EP35
# Vercel ダッシュボード → Storage → Blob でストアを作成し、
# 発行される Read/Write トークンを貼る。
# ※ 未設定の間は講座作成フォームの画像アップロードが自動で無効化され、
#    講座一覧は「No Image」プレースホルダで動作する（鍵待ちでもビルド・起動可）。
BLOB_READ_WRITE_TOKEN=
